# VibeSafe 환경 변수 예시
# 이 파일을 .env로 복사하여 실제 값을 채워 넣으세요
# .env 파일은 절대 git에 커밋하지 마세요

# ─── AI (필수) ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── 데이터베이스 (필수) ───────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=vibesafe
POSTGRES_USER=vibesafe_user
POSTGRES_PASSWORD=your-secure-password
POSTGRES_SSLMODE=require

# ─── Redis (필수) ──────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
REDIS_SSL=true

# ─── AWS (프로덕션) ───────────────────────────────────────
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=ap-northeast-2
S3_BUCKET_REPORTS=vibesafe-reports-prod
S3_BUCKET_UPLOADS=vibesafe-uploads-prod

# ─── 앱 설정 ──────────────────────────────────────────────
ENVIRONMENT=development
MAX_SCAN_TIMEOUT=300
MAX_UPLOAD_SIZE_MB=500
MAX_CONCURRENT_SCANS_PER_USER=3
